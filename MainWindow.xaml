<Window x:Class="NOPRO.MainWindow"
        Icon="NOPRO.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:NOPRO"
        Closing="Window_Closing"
        mc:Ignorable="d"
        Title="NEWNOPRO" Height="800" Width="1280" 
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource MainBgColor}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" x:Name="MainStackPanel">
                <!-- Сюда мы будем последовательно вставлять наши блоки -->


                <!-- БЛОК 1: МАРКЕР И НАЗВАНИЕ -->
                <Border Style="{StaticResource RoundedPanel}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <!-- Левая часть: Маркер и H1 -->
                            <ColumnDefinition Width="1*"/>
                            <!-- Правая часть: Окно InWidth (Парсер) -->
                        </Grid.ColumnDefinitions>

                        <!-- ЛЕВАЯ СТОРОНА -->
                        <StackPanel Grid.Column="0" Margin="10">
                            <!-- Поле МАРКЕР -->
                            <TextBlock Text="МАРКЕР (InMarker)" Foreground="{StaticResource TextColor}" Margin="0,0,0,5" FontSize="14" FontWeight="SemiBold"/>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Овал Copy -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Ромб Clear -->
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InMarker" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                                <Button x:Name="CpMarker" Grid.Column="1" Content="Copy Marker" Margin="5,0,34,0" Click="CpMarker_Click"/>
                                <Button x:Name="ClMarker" Grid.Column="1" Content="clean" Background="{StaticResource ClearButtonColor}" Click="ClMarker_Click" ToolTip="Очистить Маркер" Grid.ColumnSpan="2" Margin="78,10,0,0"/>
                            </Grid>

                            <!-- Поле H1 (Название) -->
                            <TextBlock Text="ЗАГОЛОВОК H1 (InMainTitle)" Foreground="{StaticResource TextColor}" Margin="0,10,0,5" FontSize="14" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InMainTitle" Height="35" VerticalContentAlignment="Center" Padding="5" Margin="0,0,23,0"/>
                                <Button x:Name="CpMainTitle" Content="Copy Title" Margin="681,0,33,0" Click="CpMainTitle_Click" Grid.ColumnSpan="3"/>
                                <Button x:Name="ClMainTitle" Grid.Column="1" Content="clean" Background="{StaticResource ClearButtonColor}" Click="ClMainTitle_Click" ToolTip="Очистить H1" Grid.ColumnSpan="2" Margin="55,10,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- ПРАВАЯ СТОРОНА: ПАРСЕР -->
                        <StackPanel Grid.Column="1" Margin="10">
                            <TextBlock Text="Окно ввода(разделы) HTML (InSect)" Foreground="{StaticResource TextColor}" Margin="0,0,0,5" FontSize="14" FontWeight="SemiBold"/>
                            <TextBox x:Name="InWidth" Height="130" TextWrapping="Wrap" AcceptsReturn="True" 
                     Background="{StaticResource SecondaryBgColor}" Foreground="{StaticResource ValueTextColor}" BorderThickness="1" BorderBrush="#415A77" Padding="5"
                     TextChanged="InWidth_TextChanged"
                     ToolTip="Вставь сюда структуру, и она разлетится по ячейкам"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- БЛОК 2: ДАННЫЕ (Глубина, Ширина, N-Граммы) -->
                <Border Style="{StaticResource RoundedPanel}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <!-- Глубина -->
                            <ColumnDefinition Width="1*"/>
                            <!-- Ширина и N-Граммы -->
                        </Grid.ColumnDefinitions>

                        <!-- ГЛУБИНА (5 пар окон) -->
                        <StackPanel Grid.Column="0" Margin="10">
                            <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                <TextBlock Text="ГЛУБИНА (Depth)" Foreground="{StaticResource TextColor}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button x:Name="ClDepth" DockPanel.Dock="Right" Content="clean" Background="{StaticResource ClearButtonColor}" Click="ClDepth_Click" ToolTip="Очистить Глубину" Width="40"/>
                            </DockPanel>



                            <!-- Генерируем 5 строк ввода Текст + Значение -->
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InDepthT_1" TextChanged="InDepthT_1_TextChanged" Margin="2" Height="25" Padding="4,2" ToolTip="Параметр 1" Tag="DepthT"/>
                                <TextBox x:Name="InDepthV_1" Grid.Column="1" Margin="2" Height="25" Padding="4,2" HorizontalContentAlignment="Center" ToolTip="Значение 1" Tag="DepthV"/>

                            </Grid>
                            <!-- ... Аналогично для остальных 4-х строк (я сокращу код для краткости, добавь их по образцу InDepthT_2, InDepthV_2 и т.д.) ... -->
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InDepthT_2" TextChanged="InDepthT_1_TextChanged" Margin="2" Height="25" Padding="4,2" ToolTip="Параметр 1" Tag="DepthT"/>
                                <TextBox x:Name="InDepthV_2" Grid.Column="1" Margin="2" Height="25" Padding="4,2" HorizontalContentAlignment="Center" ToolTip="Значение 1" Tag="DepthV"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InDepthT_3" TextChanged="InDepthT_1_TextChanged" Margin="2" Height="25" Padding="4,2" ToolTip="Параметр 1" Tag="DepthT"/>
                                <TextBox x:Name="InDepthV_3" Grid.Column="1" Margin="2" Height="25" Padding="4,2" HorizontalContentAlignment="Center" ToolTip="Значение 1" Tag="DepthV"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InDepthT_4" TextChanged="InDepthT_1_TextChanged" Margin="2" Height="25" Padding="4,2" ToolTip="Параметр 1" Tag="DepthT"/>
                                <TextBox x:Name="InDepthV_4" Grid.Column="1" Margin="2" Height="25" Padding="4,2" HorizontalContentAlignment="Center" ToolTip="Значение 1" Tag="DepthV"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="InDepthT_5" TextChanged="InDepthT_1_TextChanged" Margin="2" Height="25" Padding="4,2" ToolTip="Параметр 1" Tag="DepthT"/>
                                <TextBox x:Name="InDepthV_5" Grid.Column="1" Margin="2" Height="25" Padding="4,2" HorizontalContentAlignment="Center" ToolTip="Значение 1" Tag="DepthV"/>
                            </Grid>
                        </StackPanel>

                        <!-- ШИРИНА И N-ГРАММЫ -->
                        <StackPanel Grid.Column="1" Margin="10">
                            <!-- Ширина -->
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Text="ШИРИНА (InWidth)" Foreground="{StaticResource TextColor}" FontSize="14" FontWeight="SemiBold"/>
                                <Button x:Name="ClWidth" DockPanel.Dock="Right" Content="clean" Background="{StaticResource ClearButtonColor}" Click="ClWidth_Click" Margin="400,0,0,0" Width="50"/>
                            </DockPanel>
                            <TextBox x:Name="InWidthData" Height="60" TextWrapping="Wrap" Margin="0,0,0,15" Padding="5" TextChanged="InWidthData_TextChanged"/>

                            <!-- N-Граммы -->
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Text="N-ГРАММЫ (InNGrams)" Foreground="{StaticResource TextColor}" FontSize="14" FontWeight="SemiBold"/>
                                <Button x:Name="ClNGrams" DockPanel.Dock="Right" Content="clean" Background="{StaticResource ClearButtonColor}" Click="ClNGrams_Click" Margin="370,0,0,0" Width="50"/>
                            </DockPanel>
                            <TextBox x:Name="InNGrams" AcceptsReturn="True"  Height="60" TextWrapping="Wrap" Padding="5" TextChanged="InNGrams_TextChanged" ToolTip="Вставь столбиком, я сделаю строку"/>
                        </StackPanel>
                    </Grid>
                </Border>


                <!-- БЛОК 3: УСЛОВИЯ (УПРАВЛЕНИЕ ПРОМПТАМИ) -->
                <Border Style="{StaticResource RoundedPanel}" Margin="0,0,0,20">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- ГЛАВНАЯ СТРОКА: Tg + СТАТЬЯ + Cp-овальные (лево/центр/право) -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <!-- ЛЕВАЯ ЧАСТЬ: ToggleButtons + 4 овала (CpMeta, CpFAQ, CpInCon, CpQuotes) -->
                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="В СТАТЬЮ" Foreground="{StaticResource TextColor}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <UniformGrid Columns="3">
                                    <ToggleButton x:Name="TgInput" Content="Введение" Style="{StaticResource RoundedToggleStyle}" Margin="2"/>
                                    <ToggleButton x:Name="TgConcl" Content="Заключение" Style="{StaticResource RoundedToggleStyle}" Margin="2"/>
                                    <ToggleButton x:Name="TgMeta" Content="Метатеги" Style="{StaticResource RoundedToggleStyle}" Margin="2"/>
                                    <ToggleButton x:Name="TgTable" Content="Таблицы" Style="{StaticResource RoundedToggleStyle}" Margin="2"/>
                                    <ToggleButton x:Name="TgFAQ" Content="FAQ" Style="{StaticResource RoundedToggleStyle}" Margin="2"/>
                                    <ToggleButton x:Name="TgAnchor" Content="Анкор" Style="{StaticResource RoundedToggleStyle}" Margin="2"/>
                                    <ToggleButton x:Name="TgOpinion" Content="О компании" Style="{StaticResource RoundedToggleStyle}" Margin="2"/>
                                    <ToggleButton x:Name="TgAdd1" Content="ADD 1" Style="{StaticResource RoundedToggleStyle}" Margin="8"/>
                                    <ToggleButton x:Name="TgAdd2" Content="ADD 2" Style="{StaticResource RoundedToggleStyle}" Margin="8"/>
                                </UniformGrid>

                                <!-- 4 овала — теперь здесь -->
                                <UniformGrid Columns="2" Margin="0,10,0,0" Height="76">
                                    <Button x:Name="CpMeta" Content="Метатеги" Click="CpMeta_Click" Margin="2"/>
                                    <Button x:Name="CpFAQ" Content="FAQ" Click="CpFAQ_Click" Margin="2"/>
                                    <Button x:Name="CpInCon" Content="Введ+Закл" Click="CpInCon_Click" Margin="2"/>
                                    <Button x:Name="CpQuotes" Content="Цитаты" Click="CpQuotes_Click" Margin="2"/>
                                </UniformGrid>
                            </StackPanel>

                            <!-- ЦЕНТР: ГЛАВНЫЙ СБОРЩИК (СТАТЬЯ) -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button x:Name="CpMainPrompt" Click="CpMainPrompt_Click" Height="100" Width="90" Background="#415A77">
                                    <TextBlock Text="СТАТЬЯ" FontWeight="Bold" FontSize="16"/>
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="45"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <Button x:Name="ClCond" Content="clean" Background="{StaticResource ClearButtonColor}" Width="40" Margin="0,10,0,0" Click="ClCond_Click" ToolTip="Очистить блок Условия"/>
                            </StackPanel>

                            <!-- ПРАВАЯ ЧАСТЬ: Поля + 2 новых овала (CpAnchor, CpOpinion) -->
                            <StackPanel Grid.Column="2" Margin="5">
                                <!-- Анкор: Текст -->
                                <TextBlock Text="Текст анкора" Foreground="{StaticResource TextColor}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="InAnchorT" Height="28" Margin="2" ToolTip="Текст анкора"/>

                                <!-- Анкор: Ссылка -->
                                <TextBlock Text="Ссылка" Foreground="{StaticResource TextColor}" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,4"/>
                                <TextBox x:Name="InAnchorL" Height="28" Margin="2" ToolTip="Ссылка"/>

                                <!-- О компании -->
                                <TextBlock Text="О компании" Foreground="{StaticResource TextColor}" FontSize="13" FontWeight="SemiBold" Margin="0,6,0,4"/>
                                <TextBox x:Name="InOpinion" Height="50" Margin="2" TextWrapping="Wrap" ToolTip="О компании"/>

                                <!-- 2 новых овала -->
                                <UniformGrid Columns="2" Margin="0,10,0,0" Height="27">
                                    <Button x:Name="CpAnchor" Content="Анкор" Click="CpAnchor_Click" Margin="2"/>
                                    <Button x:Name="CpCompany" Content="О компании" Click="CpCompany_Click" Margin="2"/>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>

                        <!-- НИЖНИЙ РЯД: ДОП. БЛОКИ и ПРОВЕРКА -->
                        <UniformGrid Grid.Row="1" Columns="2" Margin="0,15,0,0">
                            <StackPanel Margin="5,5,14,10">
                                <TextBlock Text="ДОП. БЛОКИ" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <UniformGrid Columns="3" Height="25">
                                    <Button x:Name="CpChart" Content="График" Click="CpChart_Click" Margin="2"/>
                                    <Button x:Name="CpBlockAd1" Content="Add 1" Click="CpBlockAd1_Click" Margin="2"/>
                                    <Button x:Name="CpBlockAd2" Content="Add 2" Click="CpBlockAd2_Click" Margin="2"/>
                                </UniformGrid>
                            </StackPanel>
                            <StackPanel Margin="5">
                                <TextBlock Text="ПРОВЕРКА" Foreground="{StaticResource TextColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <UniformGrid Columns="3" Height="35">
                                    <Button x:Name="CpSpell" Content="Орфогр" Click="CpSpell_Click" Margin="2"/>
                                    <Button x:Name="CpLegal" Content="Закон" Click="CpLegal_Click" Margin="2"/>
                                    <Button x:Name="CpNarr" Content="Повеств" Click="CpNarr_Click" Margin="2"/>
                                </UniformGrid>
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </Border>



                <!-- Контейнер для динамических H2 и H3 -->
                <StackPanel x:Name="SectionsContainer" Margin="0,10,0,0"/>


                <TextBlock Text="РАЗДЕЛЫ H2 и H3" 
                           FontSize="17" FontWeight="Bold" 
                           Foreground="{StaticResource TextColor}" 
                           Margin="0,0,0,20" HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопка Админки -->
        <Button Content="⚙️ Админка"
        Click="OpenAdminPanel_Click"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,20,20"
        Padding="8,4"
        Background="{StaticResource AccentColor}"
        Foreground="{StaticResource TextColor}"
        BorderThickness="0" />

    </Grid>


</Window>
    