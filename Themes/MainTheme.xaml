
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib">


        <!-- Цветовая палитра Midnight Blue -->
        <SolidColorBrush x:Key="MainBgColor" Color="#0D1B2A"/>
            <!-- Темно-синий фон -->
            <SolidColorBrush x:Key="SecondaryBgColor" Color="#1B263B"/>
                <!-- Окна и панели -->
                <SolidColorBrush x:Key="AccentColor" Color="#415A77"/>
                    <!-- Акцент (как корпус iPhone) -->
                    <SolidColorBrush x:Key="TextColor" Color="#E0E1DD"/>
                        <!-- Светлый текст -->
    <!-- Дополнительные цвета -->
    <SolidColorBrush x:Key="ValueTextColor" Color="#A9D6E5"/>
    <SolidColorBrush x:Key="ClearButtonColor" Color="#C1121F"/>

    <!-- Стиль для закругленных панелей (Border) -->
                        <Style x:Key="RoundedPanel" TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource SecondaryBgColor}"/>
                                <Setter Property="CornerRadius" Value="12"/>
                                    <Setter Property="Padding" Value="10"/>
                                        <Setter Property="Margin" Value="5"/>
                        </Style>

                        <!-- Стиль для кнопок -->
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                                    <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="8" 
                            BorderThickness="0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                        </Style>

    <!-- Стиль для всех полей ввода (TextBox) -->
    <Style TargetType="TextBox">
        <!-- Основные настройки, которые видны ВСЕГДА -->
        <Setter Property="Background" Value="#1B263B" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#415A77" />
        <!-- Цвет корпуса iPhone 13 Blue -->
        <Setter Property="BorderThickness" Value="2" />
        <!-- Сделали рамку потолще (2 пикселя) -->
        <Setter Property="Padding" Value="5,2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="false" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Когда мышь наведена, рамка становится чуть светлее -->
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="border" Property="BorderBrush" Value="#778DA9" />
                        </Trigger>
                        <!-- Когда начинаем печатать, рамка загорается неоновым бирюзовым -->
                        <Trigger Property="IsFocused" Value="true">
                            <Setter TargetName="border" Property="BorderBrush" Value="#00F2FF" />
                            <Setter TargetName="border" Property="Background" Value="#151E2D" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <!-- СТИЛЬ ДЛЯ КРУГОВ (TOGGLEBUTTON) -->
    <Style x:Key="RoundedToggleStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="#1B263B"/>
        <!-- Темный фон в покое -->
        <Setter Property="Foreground" Value="#A9D6E5"/>
        <!-- Голубоватый текст -->
        <Setter Property="BorderBrush" Value="#415A77"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="border" 
                        CornerRadius="15" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Эффект при наведении -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="#778DA9"/>
                        </Trigger>
                        <!-- Эффект ВКЛЮЧЕНИЯ (IsChecked) — загорается неоном -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#00F2FF"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#00F2FF"/>
                            <Setter Property="Foreground" Value="#0D1B2A"/>
                            <!-- Темный текст на ярком фоне -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
