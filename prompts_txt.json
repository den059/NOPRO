    "Name": "CpQuotes",
    "Template": "\u0421\u0434\u0435\u043B\u0430\u0439 \u0432 html \u0438 CSS, \u0431\u043B\u043E\u043A \u0441 \u0446\u0438\u0442\u0430\u0442\u0430\u043C\u0438, \u0437\u0430\u0433\u043E\u043B\u043E\u0432\u043A\u043E\u043C \u003Cdiv\u003E, \u0438 \u0442\u0435\u043A\u0441\u0442\u043E\u043C \u0443\u043C\u0435\u0441\u0442\u043D\u044B\u043C \u043A \u044D\u0442\u043E\u043C\u0443 \u0443\u0447\u0430\u0441\u0442\u043A\u0443 \u0441\u0442\u0430\u0442\u044C\u0438. \u0412\u0430\u0436\u043D\u043E, \u0447\u0442\u043E\u0431\u044B \u0431\u043B\u043E\u043A\u0438 \u043D\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0438 \u0442\u0435\u043A\u0441\u0442\u0430 \u0438\u0437 \u0441\u0442\u0430\u0442\u044C\u0438, \u0431\u044B\u043B\u0438 \u043A\u043E\u0440\u043E\u0442\u043A\u0438 \u0438 \u043F\u043E\u043B\u0435\u0437\u043D\u044B \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u044E, \u0434\u043E\u043F\u043E\u043B\u043D\u044F\u043B\u0438 \u0442\u0435\u043A\u0443\u0449\u0438\u0439 \u0440\u0430\u0437\u0434\u0435\u043B \u0441\u0442\u0430\u0442\u044C\u0438. \u0426\u0432\u0435\u0442\u043E\u0432\u0430\u044F \u043F\u0430\u043B\u0438\u0442\u0440\u0430 \u043F\u043E \u0442\u0435\u043C\u0435 \u0441\u0442\u0430\u0442\u044C\u0438, \u0441\u0435\u0440\u044B\u0435 \u043E\u0442\u0442\u0435\u043D\u043A\u0438.\r\n\r\n\u0427\u0430\u0441\u0442\u044C \u044D\u0442\u043E\u0439 \u0440\u0430\u0437\u043C\u0435\u0442\u043A\u0438 \u043D\u0435 \u043D\u0443\u0436\u043D\u0430 !DOCTYPE html\u003E\r\n\u003Chtml lang=\u0022ru\u0022\u003E\r\n\u003Chead\u003E\r\n    \u003Cmeta charset=\u0022UTF-8\u0022\u003E\r\n    \u003Cmeta name=\u0022viewport\u0022 content=\u0022width=device-width, initial-scale=1.0\u0022\u003E\r\n    \u003Ctitle\u003E{InMarker}\u003C/title\u003E, \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0438\u0441\u0442\u044B\u0439 html \u0438 css.\r\n\r\n\u0422\u0430\u043A \u0436\u0435 \u043D\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u04